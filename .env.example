# Application Port
PORT=3333

# Database Configuration (Docker)
DB_USER=admin
DB_PASSWORD=admin
DB_NAME=feedback_hub
DB_HOST=localhost
DB_PORT=5432

# Prisma Database URL
DATABASE_URL="postgresql://admin:admin@localhost:5434/feedback_hub?schema=public"

# JWT Configuration
JWT_SECRET=super_secret_jwt_key_here
JWT_EXPIRES_IN=1d

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000