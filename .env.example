# Application Port
PORT=3000

# Database Configuration (Docker)
DB_USER=admin
DB_PASSWORD=admin
DB_NAME=feedback_hub
DB_HOST=localhost
DB_PORT=5432

# Prisma Database URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"